# توکن ربات تلگرام (از BotFather می‌گیری)
BOT_TOKEN=123456:ABC-DEF...

# آدرس دیتابیس (SQLite برای شروع)
DATABASE_URL=sqlite+aiosqlite:///./novavpn.db

# آدرس و اطلاعات ورود پنل 3x-ui (فاز بعدی استفاده می‌شود)
SANAEI_PANEL_URL=https://your-panel.com:2053
SANAEI_USERNAME=admin
SANAEI_PASSWORD=admin

# آیدی عددی تلگرام ادمین‌ها (با کاما جدا کن اگر چند نفر هستند)
ADMIN_TELEGRAM_IDS=111111111
